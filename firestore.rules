rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /posts/{postId} {
      allow read, write: if true;
    }

    match /media/{mediaId} {
      allow read, write: if true;
    }

    match /contacts/{contactId} {
      allow read, write: if true;
    }
  }
}
